{
  "name": "@illumine/unminify",
  "version": "0.0.1",
  "description": "Reverse production transforms to make JavaScript readable again",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "unminify": "./src/bin.ts"
  },
  "files": [
    "lib"
  ],
  "keywords": [
    "unminify",
    "beautify",
    "readable",
    "babel",
    "javascript",
    "ast"
  ],
  "homepage": "https://github.com/unbyte/illumine/tree/main/packages/unminify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unbyte/illumine.git",
    "directory": "packages/unminify"
  },
  "bugs": {
    "url": "https://github.com/unbyte/illumine/issues"
  },
  "author": {
    "name": "unbyte",
    "url": "https://github.com/unbyte"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@babel/generator": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@commander-js/extra-typings": "catalog:",
    "commander": "catalog:",
    "jsesc": "catalog:",
    "oxfmt": "catalog:"
  },
  "devDependencies": {
    "@illumine/test-utils": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "main": "lib/index.cjs",
    "module": "lib/index.js",
    "types": "lib/index.d.cts",
    "bin": {
      "unminify": "./lib/bin.js"
    },
    "exports": {
      ".": {
        "import": {
          "types": "./lib/index.d.ts",
          "default": "./lib/index.js"
        },
        "require": {
          "types": "./lib/index.d.cts",
          "default": "./lib/index.cjs"
        }
      }
    }
  }
}
